# Ejemplo de variables de entorno
# Copia este archivo como .env y completa con tus propios valores

# Supabase Configuration
# Obtén estos valores desde https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=tu_url_de_supabase_aqui
SUPABASE_ANON_KEY=tu_anon_key_de_supabase_aqui

# Gemini API Key para evaluaciones con IA
# Obtén tu API key desde https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_gemini_api_key_aqui
